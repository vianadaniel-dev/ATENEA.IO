# ============================================================================
# Archivo .env.example - Copia este archivo a .env y completa los valores
# ============================================================================
# IMPORTANTE: NUNCA comitas el archivo .env a git (contiene credenciales)
# ============================================================================

# === BASE DE DATOS (Supabase / PostgreSQL) ===
# Obtén DATABASE_URL de: Supabase Console → Settings → Database → Connection string
DATABASE_URL=postgresql://postgres.XXXXXXXXXXXXXXXX:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

# Supabase requiere conexión SSL
DB_SSLMODE=require

# Tamaño del pool de conexiones
DB_POOL_MIN=1
DB_POOL_MAX=10

# Timeout para conectar a la base de datos (segundos)
DB_CONNECT_TIMEOUT=10

# === SEGURIDAD (JWT) ===
# Genera una clave secreta aleatoria: python -c "import secrets, base64; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
SECRET_KEY=tu-clave-secreta-aleatoria-minimo-32-caracteres

# Algoritmo para firmar JWTs (HS256 es el estándar)
ALGORITHM=HS256

# Expiración del token de acceso en minutos
ACCESS_TOKEN_EXPIRE_MINUTES=60

# === PAGINACION ===
# Número de resultados por página (por defecto)
DEFAULT_PAGE_SIZE=20

# Número máximo de resultados por página (límite)
MAX_PAGE_SIZE=100

# === APLICACION ===
# NUNCA actives DEBUG en producción
DEBUG=False
